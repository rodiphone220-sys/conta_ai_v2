# Server API URL
VITE_API_URL="http://localhost:3001"

# Ollama Configuration (Local LLM)
# Host: URL del servidor Ollama (default: http://localhost:11434)
OLLAMA_HOST="http://localhost:11434"
# Model: Modelo local instalado (usa 'ollama list' para ver tus modelos)
# Ejemplos: mi-modelo-3b:latest, llama3.2:3b, mistral, etc.
OLLAMA_MODEL="mi-modelo-3b:latest"

# Google Apps Script Web App URL for data persistence
# ACTUALIZADO: Nuevo deployment con Password column y Google Login
GOOGLE_SCRIPT_URL="https://script.google.com/macros/s/AKfycbye4vuCyvA6GLVhRCyfUSwj_ZNgoFQsIU1nn5DwUO4mBYamQl1Ju43Q7RmGtsZT978u/exec"
VITE_GOOGLE_SCRIPT_URL="https://script.google.com/macros/s/AKfycbye4vuCyvA6GLVhRCyfUSwj_ZNgoFQsIU1nn5DwUO4mBYamQl1Ju43Q7RmGtsZT978u/exec"

# Google OAuth Client ID (obtén uno en https://console.cloud.google.com/)
# 1. Ve a Google Cloud Console -> APIs & Services -> Credentials
# 2. Crea un OAuth 2.0 Client ID (tipo Web application)
# 3. Agrega authorized origins: http://localhost:3000 y tu dominio de producción
VITE_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
